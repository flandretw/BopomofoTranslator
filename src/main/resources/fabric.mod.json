{
	"schemaVersion": 1,
	"id": "bopomofo-translator",
	"version": "${version}",
	"name": "Bopomofo Translator",
	"description": "From the Minecraft universe comes a savior — the Bopomofo Translator! A super-smart mod dedicated to saving those brain-fart moments when you forgot to switch your input method!",
	"authors": [
		"flandretw"
	],
	"contact": {
		"homepage": "https://github.com/flandretw",
		"sources": "https://github.com/flandretw/BopomofoTranslator"
	},
	"license": "MIT",
	"icon": "assets/bopomofo-translator/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"flandretw.bopomofo.translator.BopomofoTranslator"
		],
		"fabric-datagen": [
			"flandretw.bopomofo.translator.BopomofoTranslatorDataGenerator"
		],
		"client": [
			"flandretw.bopomofo.translator.BopomofoTranslatorClient"
		]
	},
	"mixins": [
		"bopomofo-translator.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}